# Required for OpenAI-hosted models:
OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenAI-compatible endpoint (e.g. self-hosted gateway)
OPENAI_BASE_URL=

# Optional model override used by all three agents
ALJAMRI_CREW_MODEL=gpt-4o-mini

# Optional per-role model overrides
ALJAMRI_MANAGER_MODEL=
PAYLO_AGENT_MODEL=
SKYHUB_AGENT_MODEL=

# Telegram bridge tokens (required for aljamri-telegram-bridge)
ALJAMRI_MASTER_BOT_TOKEN=your_master_bot_token_here
ALJAMRI_PAYLO_BOT_TOKEN=your_paylo_bot_token_here
ALJAMRI_SKYHUB_BOT_TOKEN=your_skyhub_bot_token_here

# Restrict processing to specific chats (CSV list). Leave empty to allow all groups.
ALJAMRI_ALLOWED_CHAT_IDS=

# Optional runtime controls
ALJAMRI_CREW_DRY_RUN=false
ALJAMRI_PROCESS_BOT_MESSAGES=false
ALJAMRI_FORCE_INLINE_BUTTONS=true

# Optional Exa web search grounding (free-tier hardcap defaults to 1000/month)
EXA_API_KEY=
ALJAMRI_EXA_ENABLED=true
ALJAMRI_EXA_AUTO_SEARCH=true
ALJAMRI_EXA_HARDCAP_REQUESTS=1000
ALJAMRI_EXA_NUM_RESULTS=5
ALJAMRI_EXA_TIMEOUT_SECONDS=20
ALJAMRI_EXA_USAGE_FILE=.runtime/exa_usage.json
